#!/bin/sh
# admin-gate installer postinstall.
#
# Runs as root under macOS Installer.app (the only process context on
# macOS Tahoe that can modify /etc/pam.d/ and authorizationdb for
# non-Apple code). This script:
#
#   1. Tightens perms on payload files: PAM helper, PAM module, and
#      the SecurityAgent authorization plugin bundle.
#   2. Ensures /etc/pam.d/sudo_local exists (cp from Apple's template)
#      and contains the monban PAM gate line. Idempotent.
#   3. Backs up and rebinds each GATED_RIGHTS authorizationdb right to
#      the monban-auth:auth mechanism so GUI admin dialogs route to us.

LOG=/tmp/monban-admin-gate-postinstall.log
exec > "$LOG" 2>&1
set -eux

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/gated-rights.sh"

# ---------- 1. tighten payload perms ----------

chown root:wheel /usr/local/bin/monban-pam-helper
chmod 0755 /usr/local/bin/monban-pam-helper

chown root:wheel /usr/local/lib/pam/pam_monban.so
chmod 0644 /usr/local/lib/pam/pam_monban.so

chown -R root:wheel /Library/Security/SecurityAgentPlugins/monban-auth.bundle
chmod -R a+rX      /Library/Security/SecurityAgentPlugins/monban-auth.bundle

# ---------- 2. /etc/pam.d/sudo_local ----------

SUDO_LOCAL=/etc/pam.d/sudo_local
TEMPLATE=${SUDO_LOCAL}.template
TAG='# monban sudo gate'

# M4: two PAM control values, picked by the optional MONBAN_SUDO_MODE
# env var (read from /Library/Application Support/Monban/sudo_mode if
# present, else defaults to "sufficient"):
#
#   sufficient (default) — pass on FIDO2 success, fall through to
#     Apple password prompt on FIDO2 failure/cancel. Extra factor, no
#     lockout risk.
#
#   required — FIDO2 must succeed; on failure the stack still falls
#     through (auth required lets later rules run) but because Apple's
#     pam_opendirectory follows, a user without their key cannot
#     sudo. This is strict-FIDO2-only mode for users who want it.
MODE_FILE="/Library/Application Support/Monban/sudo_mode"
if [ -f "$MODE_FILE" ] && grep -qE '^required$' "$MODE_FILE" 2>/dev/null; then
    PAM_LINE='auth required /usr/local/lib/pam/pam_monban.so # monban sudo gate'
else
    PAM_LINE='auth sufficient /usr/local/lib/pam/pam_monban.so # monban sudo gate'
fi

if [ ! -f "$SUDO_LOCAL" ]; then
    if [ -f "$TEMPLATE" ]; then
        cp "$TEMPLATE" "$SUDO_LOCAL"
    else
        : > "$SUDO_LOCAL"
    fi
fi

filtered=$(grep -v -F -- "$TAG" "$SUDO_LOCAL" || true)
{
    if [ -n "$filtered" ]; then
        printf '%s\n' "$filtered"
    fi
    printf '%s\n' "$PAM_LINE"
} > "$SUDO_LOCAL"

chown root:wheel "$SUDO_LOCAL"
chmod 0444 "$SUDO_LOCAL"

# ---------- 3. authorizationdb rebinds ----------

AUTH_BACKUP_DIR=/Library/Security/SecurityAgentPlugins
AUTH_MECH_PLIST='<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>class</key>
    <string>evaluate-mechanisms</string>
    <key>comment</key>
    <string>Monban: security-key authentication for admin actions</string>
    <key>mechanisms</key>
    <array>
        <string>monban-auth:auth</string>
    </array>
    <key>shared</key>
    <true/>
    <key>timeout</key>
    <integer>300</integer>
    <key>tries</key>
    <integer>1</integer>
</dict>
</plist>'

# Reclaim rights that a previous install gated but this install no
# longer does — restore them to Apple defaults from their backup.
for backup in "$AUTH_BACKUP_DIR"/*.monban-backup; do
    [ -f "$backup" ] || continue
    right=$(basename "$backup" .monban-backup)
    still_gated=0
    for g in "${GATED_RIGHTS[@]}"; do
        [ "$g" = "$right" ] && { still_gated=1; break; }
    done
    if [ "$still_gated" -eq 0 ]; then
        security authorizationdb write "$right" < "$backup" 2>/dev/null || true
        rm -f "$backup"
    fi
done

# Back up + rebind each currently-gated right.
for right in "${GATED_RIGHTS[@]}"; do
    backup="$AUTH_BACKUP_DIR/$right.monban-backup"
    if [ ! -f "$backup" ]; then
        security authorizationdb read "$right" > "$backup" 2>/dev/null \
            && chmod 0600 "$backup"
    fi
    printf '%s' "$AUTH_MECH_PLIST" | security authorizationdb write "$right" 2>/dev/null || true
done

# ---------- 4. install receipt ----------

mkdir -p "/Library/Application Support/Monban"
date -u +"%Y-%m-%dT%H:%M:%SZ" > "/Library/Application Support/Monban/admin-gate-installed"

exit 0
