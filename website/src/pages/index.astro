---
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "@/components/starwind/card";
import { Separator } from "@/components/starwind/separator";
import Layout from "@/layouts/Layout.astro";
import YubiKey from "@/components/keys/YubiKey.astro";
import GoogleTitan from "@/components/keys/GoogleTitan.astro";
import NitroKey from "@/components/keys/NitroKey.astro";

const githubRepo = "https://github.com/flythenimbus/monban";
const releasesUrl = `${githubRepo}/releases/latest`;
const macosDownload = `${githubRepo}/releases/latest/download/monban-macos-arm64.tar.gz`;
const linuxDownload = `${githubRepo}/releases/latest/download/monban-linux-amd64.tar.gz`;
const sponsorUrl = `${githubRepo}/sponsor`;
---

<Layout title="Monban - 2FA for your files on macOS and Linux">
    <!-- Nav -->
    <nav
        class="fixed top-0 z-50 w-full border-b border-border/50 bg-background/80 backdrop-blur-lg"
    >
        <div
            class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6"
        >
            <a
                href="/"
                class="flex items-center gap-2 text-lg font-semibold tracking-tight"
            >
                <img
                    src="/ic_launcher_foreground.png"
                    alt="Monban"
                    class="size-7"
                />
                Monban
            </a>
            <div class="flex items-center gap-1">
                <Button variant="ghost" size="sm" href="#features"
                    >Features</Button
                >
                <Button variant="ghost" size="sm" href="#download"
                    >Download</Button
                >
                <Separator orientation="vertical" class="!mx-2 !h-5" />
                <Button
                    variant="ghost"
                    size="icon-sm"
                    href={githubRepo}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub"
                >
                    <svg class="size-4" fill="currentColor" viewBox="0 0 24 24"
                        ><path
                            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                        ></path></svg
                    >
                </Button>
            </div>
        </div>
    </nav>

    <main>
        <!-- Hero -->
        <section class="relative overflow-hidden pt-32 pb-24 px-6">
            <!-- Gradient glow -->
            <div class="pointer-events-none absolute inset-0 overflow-hidden">
                <div
                    class="absolute top-[-20%] left-1/2 -translate-x-1/2 h-[500px] w-[800px] rounded-full bg-primary/8 blur-3xl"
                >
                </div>
            </div>

            <div class="relative mx-auto max-w-3xl text-center">
                <div class="flex items-center justify-center gap-2 mb-8">
                    <Badge variant="outline" size="md">
                        <svg
                            class="size-3.5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
                            ></path></svg
                        >
                        2FA for your filesystem
                    </Badge>
                    <Badge variant="ghost" size="md">
                        Free & open source
                    </Badge>
                </div>

                <h1
                    class="text-5xl sm:text-6xl font-bold tracking-tight leading-[1.1] mb-6"
                >
                    Two-factor security<br />for your <span
                        class="text-primary-accent">files</span
                    >
                </h1>

                <p
                    class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 leading-relaxed"
                >
                    Monban encrypts your folders and individual files with
                    AES-256-GCM on macOS and Linux, unlocked only by security
                    key PIN + touch. No drivers, no kernel extensions, nothing
                    to configure.
                </p>

                <div
                    class="flex flex-col sm:flex-row items-center justify-center gap-3"
                >
                    <Button
                        size="lg"
                        href="#download"
                        class="!bg-[length:200%_100%] !bg-[position:0%_0%] hover:!bg-[position:100%_0%] !bg-gradient-to-r !from-yellow-500 !via-amber-500 !to-orange-400 text-white transition-[background-position] duration-300 ease-in-out"
                    >
                        <svg
                            class="size-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                            ></path></svg
                        >
                        Download
                    </Button>
                    <Button
                        variant="outline"
                        size="lg"
                        href={githubRepo}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        View on GitHub
                        <svg
                            class="size-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                            ></path></svg
                        >
                    </Button>
                </div>
            </div>
        </section>

        <!-- Features -->
        <section id="features" class="py-24 px-6">
            <div class="mx-auto max-w-5xl">
                <div class="text-center mb-16">
                    <Badge variant="ghost" size="sm" class="mb-4"
                        >Features</Badge
                    >
                    <h2 class="text-3xl font-bold tracking-tight mb-3">
                        Why Monban
                    </h2>
                    <p class="text-muted-foreground max-w-lg mx-auto">
                        Hardware-bound encryption for folders and files on macOS
                        and Linux. No cloud, no passwords to forget.
                    </p>
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <Card>
                        <CardHeader>
                            <div
                                class="mb-3 inline-flex size-10 items-center justify-center rounded-lg bg-primary/10"
                            >
                                <svg
                                    class="size-5 text-primary-accent"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M7.864 4.243A7.5 7.5 0 0119.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 004.5 10.5a48.667 48.667 0 00-1.409 8.267m11.016-9.346a3.375 3.375 0 10-5.214 2.886A1.125 1.125 0 008.5 12.67v.618A2.625 2.625 0 0011.096 15.9l.318.094a1.125 1.125 0 00.672 0l.318-.094A2.625 2.625 0 0015 13.288v-.618a1.125 1.125 0 00-.393-.86 3.375 3.375 0 00-.5-5.239z"
                                    ></path></svg
                                >
                            </div>
                            <CardTitle>PIN + touch</CardTitle>
                            <CardDescription>
                                Unlocking requires your security key PIN and a
                                physical touch. The secret never leaves the
                                hardware -- the lock is cryptographic, not
                                UI-based.
                            </CardDescription>
                        </CardHeader>
                    </Card>

                    <Card>
                        <CardHeader>
                            <div
                                class="mb-3 inline-flex size-10 items-center justify-center rounded-lg bg-primary/10"
                            >
                                <svg
                                    class="size-5 text-primary-accent"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"
                                    ></path></svg
                                >
                            </div>
                            <CardTitle>macOS and Linux</CardTitle>
                            <CardDescription>
                                Works natively on macOS (Apple Silicon & Intel)
                                and Linux. No macFUSE, no kernel extensions, no
                                Recovery Mode reboots.
                            </CardDescription>
                        </CardHeader>
                    </Card>

                    <Card>
                        <CardHeader>
                            <div
                                class="mb-3 inline-flex size-10 items-center justify-center rounded-lg bg-primary/10"
                            >
                                <svg
                                    class="size-5 text-primary-accent"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"
                                    ></path></svg
                                >
                            </div>
                            <CardTitle>Multi-key backup</CardTitle>
                            <CardDescription>
                                Register multiple security keys per vault. Lose
                                one, use the other. Your master secret is
                                wrapped independently per key via FIDO2
                                hmac-secret.
                            </CardDescription>
                        </CardHeader>
                    </Card>

                    <Card>
                        <CardHeader>
                            <div
                                class="mb-3 inline-flex size-10 items-center justify-center rounded-lg bg-primary/10"
                            >
                                <svg
                                    class="size-5 text-primary-accent"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
                                    ></path></svg
                                >
                            </div>
                            <CardTitle>Auto-lock</CardTitle>
                            <CardDescription>
                                Vaults lock automatically on sleep, logout, app
                                quit, key removal, and SIGTERM. No chance of
                                leaving files exposed by accident.
                            </CardDescription>
                        </CardHeader>
                    </Card>

                    <Card>
                        <CardHeader>
                            <div
                                class="mb-3 inline-flex size-10 items-center justify-center rounded-lg bg-primary/10"
                            >
                                <svg
                                    class="size-5 text-primary-accent"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M3.98 8.223A10.477 10.477 0 001.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"
                                    ></path></svg
                                >
                            </div>
                            <CardTitle>Metadata protection</CardTitle>
                            <CardDescription>
                                Manifests are encrypted. Original filenames and
                                directory structure are not visible when locked.
                            </CardDescription>
                        </CardHeader>
                    </Card>

                    <Card>
                        <CardHeader>
                            <div
                                class="mb-3 inline-flex size-10 items-center justify-center rounded-lg bg-primary/10"
                            >
                                <svg
                                    class="size-5 text-primary-accent"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
                                    ></path></svg
                                >
                            </div>
                            <CardTitle>Crash-safe</CardTitle>
                            <CardDescription>
                                A write-ahead journal ensures files are never
                                lost during lock or unlock, even on power
                                failure. Streaming 64KB chunks keep memory usage
                                low.
                            </CardDescription>
                        </CardHeader>
                    </Card>
                </div>
            </div>
        </section>

        <!-- Works with -->
        <section class="py-24 px-6 border-t border-border/50">
            <div class="mx-auto max-w-5xl">
                <div class="text-center mb-12">
                    <Badge variant="ghost" size="sm" class="mb-4"
                        >Compatible Hardware</Badge
                    >
                    <h2 class="text-3xl font-bold tracking-tight mb-3">
                        Works with
                    </h2>
                    <p class="text-muted-foreground max-w-lg mx-auto">
                        Any FIDO2 security key with hmac-secret support.
                    </p>
                </div>

                <div class="relative overflow-hidden">
                    <div class="flex animate-scroll gap-12 items-center w-max">
                        <div class="flex gap-12 items-center shrink-0">
                            <div class="flex flex-col items-center gap-3 w-28">
                                <YubiKey
                                    class="h-10 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >YubiKey</span
                                >
                            </div>
                            <div class="flex flex-col items-center gap-3 w-28">
                                <GoogleTitan
                                    class="h-10 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >Google Titan</span
                                >
                            </div>
                            <div class="flex flex-col items-center gap-3 w-28">
                                <NitroKey
                                    class="h-10 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >Nitrokey</span
                                >
                            </div>
                            <div class="flex flex-col items-center gap-3 w-28">
                                <img
                                    src="/keys/canokey.png"
                                    alt="CanoKey"
                                    class="h-14 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >CanoKey</span
                                >
                            </div>
                        </div>
                        <!-- Duplicate for seamless loop -->
                        <div class="flex gap-12 items-center shrink-0">
                            <div class="flex flex-col items-center gap-3 w-28">
                                <YubiKey
                                    class="h-10 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >YubiKey</span
                                >
                            </div>
                            <div class="flex flex-col items-center gap-3 w-28">
                                <GoogleTitan
                                    class="h-10 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >Google Titan</span
                                >
                            </div>
                            <div class="flex flex-col items-center gap-3 w-28">
                                <NitroKey
                                    class="h-10 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >Nitrokey</span
                                >
                            </div>
                            <div class="flex flex-col items-center gap-3 w-28">
                                <img
                                    src="/keys/canokey.png"
                                    alt="CanoKey"
                                    class="h-14 text-foreground opacity-70 hover:opacity-100 transition-opacity"
                                />
                                <span class="text-xs text-muted-foreground"
                                    >CanoKey</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- How it works -->
        <section class="py-24 px-6 border-t border-border/50">
            <div class="mx-auto max-w-3xl">
                <div class="text-center mb-16">
                    <Badge variant="ghost" size="sm" class="mb-4">Setup</Badge>
                    <h2 class="text-3xl font-bold tracking-tight mb-3">
                        2FA in three steps
                    </h2>
                </div>

                <div class="space-y-8">
                    <div class="flex gap-5">
                        <div
                            class="flex shrink-0 size-10 items-center justify-center rounded-full bg-primary text-primary-foreground font-bold text-sm"
                        >
                            1
                        </div>
                        <div>
                            <h3 class="font-semibold text-lg mb-1">
                                Enroll your security key
                            </h3>
                            <p class="text-muted-foreground">
                                Open Monban, plug in your key, and tap to enroll
                                it as your second factor. Add backup keys
                                anytime.
                            </p>
                        </div>
                    </div>

                    <Separator />

                    <div class="flex gap-5">
                        <div
                            class="flex shrink-0 size-10 items-center justify-center rounded-full bg-primary text-primary-foreground font-bold text-sm"
                        >
                            2
                        </div>
                        <div>
                            <h3 class="font-semibold text-lg mb-1">
                                Add folders or files
                            </h3>
                            <p class="text-muted-foreground">
                                Select folders or individual files to protect.
                                Monban encrypts everything in place with
                                AES-256-GCM.
                            </p>
                        </div>
                    </div>

                    <Separator />

                    <div class="flex gap-5">
                        <div
                            class="flex shrink-0 size-10 items-center justify-center rounded-full bg-primary text-primary-foreground font-bold text-sm"
                        >
                            3
                        </div>
                        <div>
                            <h3 class="font-semibold text-lg mb-1">
                                PIN + touch to unlock
                            </h3>
                            <p class="text-muted-foreground">
                                Enter your PIN and touch your security key to
                                decrypt. Pull the key out and everything locks
                                instantly.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Download -->
        <section id="download" class="py-24 px-6 border-t border-border/50">
            <div class="mx-auto max-w-3xl text-center">
                <Badge variant="ghost" size="sm" class="mb-4">Get started</Badge
                >
                <h2 class="text-3xl font-bold tracking-tight mb-3">
                    Download Monban
                </h2>
                <p class="text-muted-foreground mb-10">
                    Grab the latest release for your platform.
                </p>

                <div
                    class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto"
                >
                    <Card
                        class="!py-0 !gap-0 group hover:border-primary/30 transition-colors"
                    >
                        <a href={macosDownload} class="block">
                            <CardContent class="flex items-center gap-4 py-4">
                                <div
                                    class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-muted group-hover:bg-primary/10 transition-colors"
                                >
                                    <svg
                                        class="size-6 text-muted-foreground group-hover:text-primary-accent transition-colors"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                                        ></path></svg
                                    >
                                </div>
                                <div class="text-left">
                                    <div class="text-xs text-muted-foreground">
                                        Download for
                                    </div>
                                    <div class="font-semibold">macOS</div>
                                    <div class="text-xs text-muted-foreground">
                                        Apple Silicon
                                    </div>
                                </div>
                                <svg
                                    class="size-4 ml-auto text-muted-foreground group-hover:text-primary-accent transition-colors"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                    ></path></svg
                                >
                            </CardContent>
                        </a>
                    </Card>

                    <Card
                        class="!py-0 !gap-0 group hover:border-primary/30 transition-colors"
                    >
                        <a href={linuxDownload} class="block">
                            <CardContent class="flex items-center gap-4 py-4">
                                <div
                                    class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-muted group-hover:bg-primary/10 transition-colors"
                                >
                                    <svg
                                        class="size-6 text-muted-foreground group-hover:text-primary-accent transition-colors"
                                        fill="currentColor"
